
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=xxx
LLM_API_KEY=xxxx

# Jenkins Connection
JENKINS_URL=http://localhost:8080
JENKINS_USER=xxxx
JENKINS_API_TOKEN=xxxxx

# To get Jenkins API token:
# 1. Open Jenkins → Log in → Click your username (top right)
# 2. Click "Configure" on the left sidebar
# 3. Scroll to "API Token" section → Click "Add new Token"
# 4. Give it a name → Click "Generate" → Copy the token here
